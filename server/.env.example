PORT=4100
PUBLIC_BASE_URL=http://localhost:4100
WEB_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-auth-jwt-secret

# Optional legacy auth server support. Must match F:\work\auth-server ACCESS_TOKEN_SECRET / SESSION_SECRET.
AUTH_ACCESS_TOKEN_SECRET=
AUTH_TOKEN_ISSUER=
AUTH_CLIENT_ID=adsduck

# Optional hosted checkout server from F:\work\payment-kit-server.
PAYMENT_KIT_BASE_URL=http://localhost:4040
PAYMENT_KIT_PROJECT_KEY=adsduck

# Optional secret for scheduled SNS metric sync workers.
METRICS_SYNC_SECRET=replace-with-random-secret
LEADERBOARD_STREAM_INTERVAL_MS=5000
