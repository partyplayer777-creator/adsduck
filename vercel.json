{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/contests/(.*)", "destination": "/api/contests?path=$1" },
    { "source": "/api/lecture/(.*)", "destination": "/api/lecture?path=$1" },
    { "source": "/api/points/(.*)", "destination": "/api/points?path=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
